{
  "name": "pomodore",
  "version": "1.0.0",
  "description": "A Pomodoro timer app built with Electron and React",
  "main": "electron-dist/main.js",
  "scripts": {
    "build:electron": "tsc -p tsconfig.node.json",
    "dev": "concurrently \"vite\" \"tsc -p tsconfig.node.json --watch\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && tsc -p tsconfig.node.json && electron-builder",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:main": "vitest --project main",
    "test:renderer": "vitest --project renderer",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@emotion/react": "^11",
    "@emotion/styled": "^11",
    "@mui/icons-material": "^5",
    "@mui/material": "^5",
    "electron-store": "^8",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^2",
    "sql.js": "^1.12.0",
    "zustand": "^4"
  },
  "devDependencies": {
    "@conarti/eslint-plugin-feature-sliced": "^1.0.5",
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4",
    "@vitest/coverage-v8": "^4.1.0",
    "concurrently": "^8",
    "electron": "^29",
    "electron-builder": "^24",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "jsdom": "^29.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^5",
    "vitest": "^4.1.0",
    "wait-on": "^7"
  },
  "build": {
    "appId": "com.pomodore.app",
    "productName": "Pomodore",
    "icon": "icon.png",
    "directories": {
      "output": "dist-electron-build"
    },
    "files": [
      "dist/**/*",
      "electron-dist/**/*",
      "icon.png",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "extraResources": [
      {
        "from": "electron-dist/",
        "to": "electron-dist/",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
